# Chave da API OpenAI — obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...sua_chave_aqui...

# Senha de acesso ao sistema (use algo forte, não apenas 4 dígitos)
ACCESS_PASSWORD=sua_senha_aqui

# Porta do servidor (opcional, padrão: 3000)
PORT=3000

# Token Bearer da APIBrasil — obtenha em https://apibrasil.io
APIBRASIL_TOKEN=seu_token_aqui

# Credenciais Suhai Seguradora (web scraping de FIPE — NUNCA expor no frontend)
SUHAI_LOGIN=seu_cpf_aqui
SUHAI_PASSWORD=sua_senha_aqui
